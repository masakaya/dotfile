" ===================================================
" File .vimrc.path
" Author : Masashi Kayahara <sylphs.mb@gmail.com >
" ===================================================

"----------------------------------------------------
" Path Setting 
"----------------------------------------------------
set path+=.,/usr/include/*,,
set path+=/usr/include/c++/4.7/
set path+=/usr/include/c++/4.8/
set path+=/usr/local/include/*

"----------------------------------------------------
" tags Setting
"----------------------------------------------------
set tags=./tags,../tags,../../tags

"----------------------------------------------------
" dictionary setting
"----------------------------------------------------
set dictionary+=$VIMHOME.'/dict/*'

